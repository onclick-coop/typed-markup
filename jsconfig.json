{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "checkJs": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["*.js"],
  "exclude": ["*.bench.js", "*.test.js", "*.config.js"]
}
